# User-Specific Environment Variables
# ===================================
#
# This file contains YOUR specific environment variables.
# Keep this file in your personal/user branch - DO NOT commit to master.
#
# This file is gitignored in master branch but tracked in personal/user branch.

# OAuth Provider Credentials
OAUTH_CLIENT_ID=your-client-id-here
OAUTH_CLIENT_SECRET=your-client-secret-here

# Cloudflare Tunnel URL
TUNNEL_URL=https://your-tunnel-url.trycloudflare.com

# Additional user-specific settings
# Add your own variables here as needed
