# ========================================================================
# MCP HTTP Proxy - Environment Variables
# ========================================================================
#
# Copy this file to .env and fill in your values.
#
# IMPORTANT: .env is gitignored - never commit secrets!
#
# ========================================================================

# Hevy API Key (get from https://hevy.app/api)
HEVY_API_KEY=your_hevy_api_key_here

# OAuth Client Secret for Claude Connectors
# Generate a secure secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
OAUTH_CLIENT_SECRET=your_generated_oauth_secret_here
