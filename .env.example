# MCP Proxy Environment Variables Example
# Copy this file to .env and customize with your values

# LibreOffice Configuration (libreoffice-calc-mcp)
MCP_LIBREOFFICE_PATH=C:/Program Files/LibreOffice/program/soffice.exe
MCP_LIBREOFFICE_HOST=localhost
MCP_LIBREOFFICE_PORT=2002
MCP_LIBREOFFICE_PROGRAM_DIR=C:/Program Files/LibreOffice/program
MCP_LIBREOFFICE_PYTHON=C:/Program Files/LibreOffice/program/python.exe

# Proxy Configuration
MCP_PROXY_PORT=8081
MCP_PROXY_HOST=127.0.0.1
MCP_PROXY_DOMAIN=your-proxy-domain.example.com

# Test Configuration
MCP_TEST_DATA_PATH=C:/path/to/your/test-spreadsheet.ods

# Hevy API Configuration (hevy-mcp-proxy)
HEVY_API_KEY=your_hevy_api_key_here

# OAuth 2.0 Authentication (Optional - for securing the proxy)
# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Session Secret (required for OAuth - generate a random string)
SESSION_SECRET=your_random_session_secret_at_least_32_characters

# Cloudflare Tunnel (Optional)
MCP_CLOUDFLARE_TUNNEL_ID=your-tunnel-id
MCP_CLOUDFLARE_CREDENTIALS=/path/to/credentials.json
